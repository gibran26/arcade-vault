{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-file.mjs",
            "timeout": 60,
            "statusMessage": "Formateando con Prettier + ESLint..."
          }
        ]
      }
    ]
  }
}
